# =============================================================================
# P4_RAG — .env.example  (committed template; copy to .env and fill real values)
# Single source of truth for variables: project_specs.md §3.1
#   cp .env.example .env   then fill from Step 0 (prompts.md / full_pipeline.md)
# PowerShell does NOT auto-export .env — pydantic-settings reads it via
# SettingsConfigDict(env_file=".env"). Ad-hoc run: $env:MODE="polling"; ...
# NEVER commit the real .env (it is gitignored).
# =============================================================================

# --- TELEGRAM ----------------------------------------------------------------
# Bot token from @BotFather (use a separate dev bot locally, prod on Railway).
TELEGRAM_BOT_TOKEN=123456789:AA-replace-with-your-botfather-token
# Negative chat_id of the MANAGERS' group (escalations land here). Get via @getmyidbot.
MANAGER_CHAT_ID=-1001234567890
# Comma-separated Telegram user IDs allowed to run /upload /sources /delete.
ADMIN_TELEGRAM_IDS=111111111
# X-Telegram-Bot-Api-Secret-Token validator (webhook mode). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=replace-with-a-32-byte-url-safe-secret
# Public HTTPS URL Railway assigns. Fill after the first deploy (webhook mode).
WEBHOOK_BASE_URL=https://your-app.up.railway.app

# --- ANTHROPIC (Claude — answer generation) ----------------------------------
# Key from console.anthropic.com. Set a Workspace spend limit there ($20/mo,
# alert $10) — the only real HARD cost cap (learnings.md #cost).
ANTHROPIC_API_KEY=sk-ant-api03-replace-with-your-key
# Generation model (Context7-verified 2026-05-26): Haiku 4.5.
ANTHROPIC_MODEL=claude-haiku-4-5
# Hard per-call output ceiling (anti-runaway). MUST be <= 1024 (enforced in config).
ANTHROPIC_MAX_TOKENS=1024

# --- VOYAGE AI (embeddings — Anthropic's recommended provider) ----------------
# Key from dashboard.voyageai.com. Claude has NO embeddings API.
VOYAGE_API_KEY=pa-replace-with-your-key
# Embedding model (OQ-1 resolved): voyage-3.5, multilingual, 1024-dim default.
VOYAGE_MODEL=voyage-3.5
# Embedding dimension — MUST match the pgvector column and VOYAGE_MODEL. Frozen at 1024.
VOYAGE_EMBED_DIM=1024

# --- GROQ (voice input via Whisper-large-v3-turbo) ---------------------------
# gsk_... key from console.groq.com. Permanent free tier, no card.
GROQ_API_KEY=gsk_replace-with-your-key

# --- SUPABASE (pgvector + Postgres — vectors, memory, escalations, feedback) --
# Project URL: Dashboard → Project Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
# Server-side secret key (bypasses RLS; NEVER ship to a client). New sb_secret_...
# key or the legacy service_role key. Verified via Context7 2026-05-26.
SUPABASE_SERVICE_KEY=sb_secret_replace-with-your-secret-key
# Postgres URL — use the SESSION POOLER (Supavisor, port 5432). The DIRECT host
# db.<ref>.supabase.co is IPv6-ONLY on the free tier, so on an IPv4 network DNS
# won't resolve it (-> "getaddrinfo failed"). The pooler always has IPv4. Session
# mode (5432) behaves like a direct connection and supports asyncpg prepared
# statements; do NOT use transaction mode (6543) with asyncpg. Note the username
# becomes postgres.<project-ref>. Dashboard: Connect -> Session pooler -> URI.
# (Context7-verified 2026-05-26.)
DATABASE_URL=postgresql://postgres.your-project-ref:[YOUR-DB-PASSWORD]@aws-0-your-region.pooler.supabase.com:5432/postgres

# --- RAG TUNING (defaults; revisited against the golden set in the eval prompt) -
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
RETRIEVAL_TOP_K=5
# Below this cosine similarity on the best chunk, the bot refuses + escalates.
SIMILARITY_THRESHOLD=0.6
# Conversation memory window kept per user (last N messages).
CONVERSATION_MEMORY_TURNS=20
# After a manager "takes" a dialogue, the bot stays silent for this user this many hours.
ESCALATION_COOLDOWN_HOURS=24

# --- RATE LIMITING (§3.3; in-memory per-user throttle) -----------------------
# Minimum seconds between any two messages from one user (anti-flood).
RATE_LIMIT_INTERVAL_SECONDS=0.7
# Max LLM-bearing messages (free-text questions + voice) per user per minute.
RATE_LIMIT_LLM_PER_MINUTE=10

# --- MODE & WEB SERVER -------------------------------------------------------
# polling (local dev) or webhook (Railway). Locally always polling.
MODE=polling
# aiohttp bind host/port for webhook mode. Ignored locally.
WEB_HOST=0.0.0.0
WEB_PORT=8080

# --- FSM STORAGE -------------------------------------------------------------
# Persistent FSM storage (project_specs.md §8 / §9.1). REQUIRED in webhook
# (production) mode — provision a Railway Redis add-on and paste its URL here.
# Leave EMPTY locally: polling falls back to in-memory storage (DEV ONLY, with a
# warning). MemoryStorage is never used in production.
REDIS_URL=

# --- OBSERVABILITY -----------------------------------------------------------
# Sentry DSN for error tracking (free tier). Leave empty to disable.
SENTRY_DSN=
# DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO
